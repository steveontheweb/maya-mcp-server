{
  "mcpServers": {
    "maya-mcp": {
      "command": "python",
      "args": [
        "-m",
        "maya_mcp.server"
      ],
      "env": {
        "PYTHONPATH": "D:/Program Files/maya-mcp-server/src",
        "MAYA_HOST": "localhost",
        "MAYA_PORT": "9877"
      },
      "alwaysAllow": [
          "get_scene_info",
          "create_primitive",
          "delete_object",
          "set_material",
          "transform_object",
          "smart_select",
          "get_scene_summary",
          "get_console_output",
          "execute_maya_code"
      ]
    }
  }
}